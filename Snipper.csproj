<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>Snipper</AssemblyName>
    <RootNamespace>Snipper</RootNamespace>
    <Version>0.1.0</Version>
  </PropertyGroup>

  <ItemGroup Condition="Exists('ffmpeg')">
    <!-- If you drop an ffmpeg.exe in ./ffmpeg/, it gets copied next to the
         output so the app is self-contained. Otherwise it falls back to an
         ffmpeg on PATH. -->
    <None Include="ffmpeg\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>ffmpeg\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </None>
  </ItemGroup>

</Project>
