<Window x:Class="Snipper.RegionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross">
    <Canvas x:Name="Root" Background="Transparent">
        <!-- Dim layer: full-screen dark with a rectangular hole over the selection -->
        <Path x:Name="DimPath" Fill="#88000000" />
        <!-- Selection border -->
        <Rectangle x:Name="SelRect" Stroke="#FF35E0C0" StrokeThickness="1.5"
                   Visibility="Collapsed" />
        <!-- Size readout -->
        <Border x:Name="SizeBadge" Background="#CC101418" CornerRadius="3"
                Padding="6,2" Visibility="Collapsed">
            <TextBlock x:Name="SizeText" Foreground="#FF35E0C0" FontFamily="Consolas"
                       FontSize="12" />
        </Border>
        <!-- Hint -->
        <Border x:Name="HintBadge" Background="#CC101418" CornerRadius="4" Padding="12,6">
            <TextBlock Foreground="#FFD0D6DA" FontFamily="Segoe UI" FontSize="13"
                       Text="Drag to select a region  ·  Esc to cancel" />
        </Border>
    </Canvas>
</Window>
