<Window x:Class="Snipper.CountdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False" Topmost="True"
        WindowState="Maximized">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="Number" Text="3" FontSize="200" FontWeight="Bold"
                       Foreground="#FF35E0C0" TextAlignment="Center"
                       FontFamily="Consolas">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="24" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
            <Border Background="#CC101418" CornerRadius="8" Padding="18,8" Margin="0,8,0,0"
                    HorizontalAlignment="Center">
                <TextBlock Text="▶  Un-pause / start your video now"
                           Foreground="#FFE8ECEE" FontSize="20" FontFamily="Segoe UI"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>
