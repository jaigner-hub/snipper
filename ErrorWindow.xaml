<Window x:Class="Snipper.ErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snipper" Height="460" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#FF0E1316">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="Heading" Grid.Row="0" Foreground="#FFE08A6F"
                   FontSize="14" FontWeight="Bold" TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1" CornerRadius="6" Background="#FF12181B"
                BorderBrush="#FF233037" BorderThickness="1">
            <TextBox x:Name="Body" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="12" Padding="10"
                     Background="Transparent" Foreground="#FFC8D0D4"
                     BorderThickness="0"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="CopyBtn" Content="Copy" Click="Copy_Click"
                    Width="100" Height="34" Margin="0,0,8,0" Cursor="Hand"/>
            <Button x:Name="SaveBtn" Content="Save log…" Click="Save_Click"
                    Width="100" Height="34" Margin="0,0,8,0" Cursor="Hand"/>
            <Button Content="Close" IsCancel="True" IsDefault="True"
                    Width="100" Height="34" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
